# Frontend/.env
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
#
# ── Local development (backend on same machine) ───────────────────────────────
VITE_API_URL=http://localhost:5001
 
# ── Docker Compose (frontend container talking to dashboard service) ──────────
# Uncomment the line below and comment out the one above when using Docker.
# VITE_API_URL=http://dashboard:5001
 
